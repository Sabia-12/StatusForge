// StatusForge — Prisma Schema
// SQLite for development, PostgreSQL-ready for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships    Membership[]
  incidents      Incident[]
  incidentUpdates IncidentUpdate[]
  auditLogs      AuditLog[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  services    Service[]
  incidents   Incident[]
  auditLogs   AuditLog[]
}

model Membership {
  id     String         @id @default(cuid())
  role   String         @default("member") // owner, admin, member, viewer

  userId String
  orgId  String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("operational") // operational, degraded, partial_outage, major_outage, maintenance
  sortOrder   Int      @default(0)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidents IncidentService[]
}

model Incident {
  id         String    @id @default(cuid())
  title      String
  status     String    @default("investigating") // investigating, identified, monitoring, resolved
  impact     String    @default("minor") // none, minor, major, critical
  orgId      String
  authorId   String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author   User              @relation(fields: [authorId], references: [id])
  services IncidentService[]
  updates  IncidentUpdate[]
}

model IncidentService {
  incidentId String
  serviceId  String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([incidentId, serviceId])
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  body       String
  status     String   // investigating, identified, monitoring, resolved
  incidentId String
  authorId   String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // create, update, delete, status_change, etc.
  entityType String   // service, incident, incident_update, user
  entityId   String
  metadata   String?  // JSON string for additional data
  userId     String
  orgId      String
  createdAt  DateTime @default(now())

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
